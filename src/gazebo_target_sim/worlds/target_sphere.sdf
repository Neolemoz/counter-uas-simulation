        </visual>
        <visual name="arm_py">
          <pose>0 0.35 0.225 0 0 0</pose>
          <geometry>
            <box>
              <size>0.075 0.35 0.075</size>
            </box>
          </geometry>
          <material>
            <ambient>0.15 0.25 0.6 1</ambient>
            <diffuse>0.25 0.4 1.0 1</diffuse>
          </material>
        </visual>
        <visual name="arm_ny">
          <pose>0 -0.35 0.225 0 0 0</pose>
          <geometry>
            <box>
              <size>0.075 0.35 0.075</size>
            </box>
          </geometry>
          <material>
            <ambient>0.15 0.25 0.6 1</ambient>
            <diffuse>0.25 0.4 1.0 1</diffuse>
          </material>
        </visual>
        <visual name="prop_px">
          <pose>0.5 0 0.225 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.0375</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.28 1</ambient>
            <diffuse>0.35 0.35 0.4 1</diffuse>
          </material>
        </visual>
        <visual name="prop_nx">
          <pose>-0.5 0 0.225 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.0375</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.28 1</ambient>
            <diffuse>0.35 0.35 0.4 1</diffuse>
          </material>
        </visual>
        <visual name="prop_py">
          <pose>0 0.5 0.225 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.0375</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.28 1</ambient>
            <diffuse>0.35 0.35 0.4 1</diffuse>
