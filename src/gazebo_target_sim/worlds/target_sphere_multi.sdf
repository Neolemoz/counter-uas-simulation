    <model name="interceptor_2">
      <static>false</static>
      <pose>-4 5 0 0 0 0</pose>
      <link name="base_link">
        <gravity>false</gravity>
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>0.05</ixx>
            <ixy>0.0</ixy>
