          <pose>0 0 0.5 0 0 0</pose>
          <geometry>
            <sphere><radius>50</radius></sphere>
          </geometry>
          <material>
            <ambient>0.85 0.15 0.55 1</ambient>
            <diffuse>1.0 0.22 0.7 1</diffuse>
            <emissive>0.32 0.04 0.18 1</emissive>
          </material>
          <transparency>0.55</transparency>
          <cast_shadows>false</cast_shadows>
        </visual>
      </link>
    </model>

    <!-- Translucent 3D shells — radii must match gazebo_target.launch.py DOME_OUTER/MIDDLE/INNER_M -->
    <model name="danger_dome_outer">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <visual name="shell">
          <geometry><sphere><radius>6000</radius></sphere></geometry>
          <material>
            <ambient>0.98 0.42 0.15 1</ambient>
            <diffuse>1.0 0.55 0.22 1</diffuse>
            <emissive>0.08 0.03 0.01 1</emissive>
          </material>
          <transparency>0.58</transparency>
          <cast_shadows>false</cast_shadows>
        </visual>
      </link>
    </model>
    <model name="danger_dome_mid">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <visual name="shell">
          <geometry><sphere><radius>3000</radius></sphere></geometry>
          <material>
            <ambient>0.98 0.88 0.2 1</ambient>
            <diffuse>1.0 0.95 0.35 1</diffuse>
            <emissive>0.06 0.05 0.02 1</emissive>
          </material>
          <transparency>0.52</transparency>
          <cast_shadows>false</cast_shadows>
        </visual>
      </link>
    </model>
    <model name="danger_dome_inner">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <visual name="shell">
          <geometry><sphere><radius>1200</radius></sphere></geometry>
          <material>
            <ambient>1.0 0.25 0.25 1</ambient>
            <diffuse>1.0 0.42 0.42 1</diffuse>
            <emissive>0.1 0.03 0.03 1</emissive>
          </material>
          <transparency>0.46</transparency>
          <cast_shadows>false</cast_shadows>
        </visual>
      </link>
    </model>

    <!-- Interceptor quadcopters: forward +X; non-static so gz set_pose from ROS moves visuals. -->
    <model name="interceptor_0">
      <static>false</static>
      <pose>-5 0 0 0 0 0</pose>
      <link name="base_link">
        <gravity>false</gravity>
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>0.05</ixx>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyy>0.05</iyy>
            <iyz>0.0</iyz>
            <izz>0.05</izz>
          </inertia>
        </inertial>
        <collision name="hull">
          <pose>0 0 0.225 0 0 0</pose>
          <geometry>
            <box>
              <size>1.3 1.3 0.45</size>
            </box>
          </geometry>
        </collision>
        <visual name="body">
          <pose>0 0 0.225 0 0 0</pose>
          <geometry>
            <box>
              <size>0.275 0.275 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.12 0.22 0.55 1</ambient>
            <diffuse>0.2 0.35 0.95 1</diffuse>
          </material>
        </visual>
        <visual name="arm_px">
          <pose>0.35 0 0.225 0 0 0</pose>
          <geometry>
            <box>
              <size>0.35 0.075 0.075</size>
            </box>
          </geometry>
          <material>
            <ambient>0.15 0.25 0.6 1</ambient>
            <diffuse>0.25 0.4 1.0 1</diffuse>
          </material>
        </visual>
        <visual name="arm_nx">
          <pose>-0.35 0 0.225 0 0 0</pose>
          <geometry>
            <box>
              <size>0.35 0.075 0.075</size>
            </box>
          </geometry>
          <material>
            <ambient>0.15 0.25 0.6 1</ambient>
            <diffuse>0.25 0.4 1.0 1</diffuse>
          </material>
        </visual>
        <visual name="arm_py">
          <pose>0 0.35 0.225 0 0 0</pose>
          <geometry>
            <box>
              <size>0.075 0.35 0.075</size>
            </box>
          </geometry>
          <material>
            <ambient>0.15 0.25 0.6 1</ambient>
            <diffuse>0.25 0.4 1.0 1</diffuse>
          </material>
        </visual>
        <visual name="arm_ny">
          <pose>0 -0.35 0.225 0 0 0</pose>
          <geometry>
            <box>
              <size>0.075 0.35 0.075</size>
            </box>
          </geometry>
          <material>
            <ambient>0.15 0.25 0.6 1</ambient>
            <diffuse>0.25 0.4 1.0 1</diffuse>
          </material>
        </visual>
        <visual name="prop_px">
          <pose>0.5 0 0.225 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.0375</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.28 1</ambient>
            <diffuse>0.35 0.35 0.4 1</diffuse>
          </material>
        </visual>
        <visual name="prop_nx">
          <pose>-0.5 0 0.225 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.0375</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.28 1</ambient>
            <diffuse>0.35 0.35 0.4 1</diffuse>
          </material>
        </visual>
        <visual name="prop_py">
          <pose>0 0.5 0.225 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.0375</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.28 1</ambient>
            <diffuse>0.35 0.35 0.4 1</diffuse>
          </material>
        </visual>
        <visual name="prop_ny">
