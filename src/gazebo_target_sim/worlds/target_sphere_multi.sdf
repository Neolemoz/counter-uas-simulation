<?xml version="1.0" ?>
<!-- Ground + target sphere + interceptor boxes. Poses updated via gz set_pose from ROS nodes. -->
<sdf version="1.8">
  <world name="counter_uas_target">
    <!-- Gazebo Sim needs MinimalScene + camera_clip; Classic <gui><camera> is ignored / can break the 3D view. -->
    <scene>
      <ambient>0.75 0.75 0.78 1</ambient>
      <background>0.82 0.84 0.88 1</background>
      <grid>true</grid>
    </scene>
    <gui fullscreen="0">
      <plugin filename="MinimalScene" name="3D View">
        <gz-gui>
          <title>3D View</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.55 0.55 0.58</ambient_light>
        <background_color>0.82 0.84 0.88</background_color>
        <!-- x y z roll pitch yaw (rad); framed on asset + traffic near origin -->
        <camera_pose>-4200 -3200 1800 0 0.42 0.85</camera_pose>
        <camera_clip>
          <near>1</near>
          <!-- default far (~1000) culls km-scale domes → empty-looking view -->
          <far>80000</far>
        </camera_clip>
      </plugin>
      <plugin filename="EntityContextMenuPlugin" name="Entity context menu">
        <gz-gui>
          <property key="state" type="string">floating</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="GzSceneManager" name="Scene Manager">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="InteractiveViewControl" name="Interactive view control">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="CameraTracking" name="Camera Tracking">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="WorldControl" name="World control">
        <gz-gui>
          <title>World control</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="bool" key="resizable">false</property>
          <property type="double" key="height">72</property>
          <property type="double" key="z">1</property>
          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="left" target="left"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </gz-gui>
        <play_pause>true</play_pause>
        <step>true</step>
        <start_paused>false</start_paused>
        <use_event>true</use_event>
      </plugin>
      <plugin filename="WorldStats" name="World stats">
        <gz-gui>
          <title>World stats</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="bool" key="resizable">false</property>
          <property type="double" key="height">110</property>
          <property type="double" key="width">290</property>
          <property type="double" key="z">1</property>
          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="right" target="right"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </gz-gui>
        <sim_time>true</sim_time>
        <real_time>true</real_time>
        <real_time_factor>true</real_time_factor>
        <iterations>true</iterations>
      </plugin>
      <plugin filename="ComponentInspector" name="Component inspector">
        <gz-gui>
          <property type="string" key="state">docked</property>
        </gz-gui>
      </plugin>
      <plugin filename="EntityTree" name="Entity tree">
        <gz-gui>
          <property type="string" key="state">docked</property>
        </gz-gui>
      </plugin>
    </gui>
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>

    <light type="directional" name="sun">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>25000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>14000 14000</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>14000 14000</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.82 0.84 0.86 1</ambient>
            <diffuse>0.88 0.9 0.92 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Multi-target world: three hostiles as neutral boxes (no orange/pink spheres). -->
    <model name="sphere_target_0">
      <static>false</static>
      <!-- Matches gazebo_target_multi.launch.py targets_cfg sphere_target_0 -->
      <pose>0 0 36 0 0 0</pose>
      <link name="base_link">
        <gravity>false</gravity>
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>0.121</ixx>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyy>0.121</iyy>
            <iyz>0.0</iyz>
            <izz>0.121</izz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry>
            <sphere>
              <radius>0.72</radius>
            </sphere>
          </geometry>
        </collision>
        <visual name="vis">
          <geometry>
            <box><size>2.2 2.2 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.22 0.24 0.28 1</ambient>
            <diffuse>0.32 0.34 0.4 1</diffuse>
            <emissive>0.05 0.05 0.08 1</emissive>
          </material>
        </visual>
        <!-- Sight halo (red): visible at km-scale camera distance; collision unchanged. -->
        <visual name="sight_icon">
          <pose>0 0 0.5 0 0 0</pose>
          <geometry>
            <sphere><radius>60</radius></sphere>
          </geometry>
          <material>
            <ambient>0.85 0.12 0.12 1</ambient>
            <diffuse>1.0 0.2 0.2 1</diffuse>
            <emissive>0.4 0.05 0.05 1</emissive>
          </material>
          <transparency>0.55</transparency>
          <cast_shadows>false</cast_shadows>
        </visual>
      </link>
    </model>
    <model name="sphere_target_1">
      <static>false</static>
      <pose>-6 5 34 0 0 0</pose>
      <link name="base_link">
        <gravity>false</gravity>
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>0.121</ixx>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyy>0.121</iyy>
            <iyz>0.0</iyz>
            <izz>0.121</izz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry>
            <sphere>
              <radius>0.72</radius>
            </sphere>
          </geometry>
        </collision>
        <visual name="vis">
          <geometry>
            <box><size>2.2 2.2 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.18 0.28 0.42 1</ambient>
            <diffuse>0.25 0.38 0.55 1</diffuse>
            <emissive>0.04 0.06 0.12 1</emissive>
          </material>
        </visual>
        <!-- Sight halo (orange): distinguishes target_1 from the primary (red) at distance. -->
        <visual name="sight_icon">
          <pose>0 0 0.5 0 0 0</pose>
          <geometry>
            <sphere><radius>50</radius></sphere>
          </geometry>
          <material>
            <ambient>0.95 0.45 0.1 1</ambient>
            <diffuse>1.0 0.55 0.18 1</diffuse>
            <emissive>0.35 0.12 0.02 1</emissive>
          </material>
          <transparency>0.55</transparency>
          <cast_shadows>false</cast_shadows>
        </visual>
      </link>
    </model>
    <model name="sphere_target_2">
      <static>false</static>
      <pose>6 -5 32 0 0 0</pose>
      <link name="base_link">
        <gravity>false</gravity>
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>0.121</ixx>
