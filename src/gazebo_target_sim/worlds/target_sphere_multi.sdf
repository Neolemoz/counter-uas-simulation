          </geometry>
          <material>
            <ambient>0.15 0.35 0.85 1</ambient>
            <diffuse>0.22 0.45 1.0 1</diffuse>
            <emissive>0.04 0.08 0.18 1</emissive>
          </material>
          <transparency>0.7</transparency>
          <cast_shadows>false</cast_shadows>
        </visual>
      </link>
    </model>

